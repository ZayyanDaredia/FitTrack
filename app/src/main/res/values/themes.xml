<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.FitTrack" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#A4FF33</item>
        <item name="colorPrimaryVariant">#121212</item>
        <item name="colorOnPrimary">#121212</item>

        <item name="colorSecondary">#A4FF33</item>
        <item name="colorSecondaryVariant">#A4FF33</item>
        <item name="colorOnSecondary">#121212</item>

        <item name="android:statusBarColor">#121212</item>

        <item name="shapeAppearanceOverlay">@style/CircleImage</item>
    </style>

    <style name="DayBoxStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">45dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#9E9E9E</item>
        <item name="android:background">#1E1E1E</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DayBoxActiveStyle" parent="DayBoxStyle">
        <item name="android:background">#A4FF33</item>
        <item name="android:textColor">#121212</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="QuickAddBox">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">8dp</item>
        <item name="android:background">@drawable/bg_quick_add</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="QuickAddIcon">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:tint">#2196F3</item>
    </style>

    <style name="QuickAddText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#9E9E9E</item>
        <item name="android:textSize">10sp</item>
        <item name="android:layout_marginTop">4dp</item>
    </style>

</resources>