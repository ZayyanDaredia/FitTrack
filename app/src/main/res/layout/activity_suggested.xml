<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"> <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Daily Recommendations"
    android:textSize="24sp"
    android:textStyle="bold"
    android:padding="20dp"
    android:textColor="#A4FF33"
    android:background="#1E1E1E"
    android:elevation="8dp"/>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutMuscles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E"
        app:tabMode="scrollable"
        app:tabGravity="fill"
        app:tabIndicatorColor="#A4FF33"
        app:tabSelectedTextColor="#A4FF33"
        app:tabTextColor="#9E9E9E"
        app:tabRippleColor="#33A4FF33"
        android:elevation="4dp"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/exerciseContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:clipToPadding="false">
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#1E1E1E"
        android:elevation="16dp">

        <Button
            android:id="@+id/btnShuffle"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SHUFFLE EXERCISES"
            android:backgroundTint="#A4FF33"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            app:cornerRadius="12dp"/>

        <Button
            android:id="@+id/btnBackSuggest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ADD SELECTED" />

    </LinearLayout>

</LinearLayout>